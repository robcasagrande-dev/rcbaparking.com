---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

// There are 11 images named rcba-parking-santa-marta-1.jpeg to rcba-parking-santa-marta-11.jpeg
const images = Array.from({ length: 11 }, (_, i) => `/images/gallery/rcba-parking-santa-marta-${i + 1}.jpeg`);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="gallery" class="section gallery-section">
  <div class="container">
    <div class="text-center mb-5">
      <h2>{t('gallery.title')}</h2>
      <p class="text-secondary">{t('gallery.desc')}</p>
    </div>

    <div class="gallery-grid">
      {images.map((src, index) => (
        <div class="gallery-item glass-panel">
          <img src={src} alt={`RCBA Parking Facility ${index + 1}`} loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-section {
    background-color: var(--bg-color);
    padding: 5rem 0;
  }

  .text-center { text-align: center; }
  .mb-5 { margin-bottom: 3rem; }
  .text-secondary { color: var(--text-secondary); }

  h2 {
    font-size: 2.5rem;
    color: var(--primary-color);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    padding: 1rem;
  }

  .gallery-item {
    overflow: hidden;
    border-radius: var(--border-radius);
    aspect-ratio: 1 / 1;
    cursor: pointer;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease, opacity 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
    opacity: 0.9;
  }
</style>
