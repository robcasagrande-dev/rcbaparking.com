---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const loc1Lat = "11.24294";
const loc1Lon = "-74.21204";

const loc2Lat = "11.24310";
const loc2Lon = "-74.21210";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="locations" class="section matrix-section">
  <div class="container">
    <div class="text-center mb-5 animate-fade-in">
      <h2>{t('routing.title')}</h2>
      <p class="text-secondary">{t('routing.desc')}</p>
    </div>

    <div class="matrix-grid">
      <!-- Location 1 -->
      <div class="matrix-card glass-panel">
        <div class="card-image">
          <img src="/images/location1.png" alt="RCBA Parking 1" loading="lazy" />
        </div>
        <div class="card-content">
          <h3>{t('routing.loc1.title')}</h3>
          <p class="address">{t('routing.loc1.addr')}</p>
          
          <ul class="distances">
            <li><span>📍 {t('routing.loc1.d1')}</span> <strong>200m (3 min)</strong></li>
            <li><span>🏛️ {t('routing.loc1.d2')}</span> <strong>100m (1 min)</strong></li>
          </ul>

          <div class="map-container">
            <iframe 
              src="https://maps.google.com/maps?q=Cra.+2+%2319-60,+Santa+Marta,+Centro+Hist%C3%B3rico&t=&z=16&ie=UTF8&iwloc=&output=embed" 
              width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
          
          <div class="routing-actions">
            <a href={`https://waze.com/ul?ll=${loc1Lat},${loc1Lon}&navigate=yes`} target="_blank" class="btn btn-secondary btn-waze">
              {t('routing.btn.waze')}
            </a>
            <a href={`https://www.google.com/maps/dir/?api=1&destination=${loc1Lat},${loc1Lon}`} target="_blank" class="btn btn-primary btn-maps">
              {t('routing.btn.maps')}
            </a>
          </div>
        </div>
      </div>

      <!-- Location 2 -->
      <div class="matrix-card glass-panel">
        <div class="card-image">
          <img src="/images/location2.png" alt="RCBA Parking 2" loading="lazy" />
        </div>
        <div class="card-content">
          <h3>{t('routing.loc2.title')}</h3>
          <p class="address">{t('routing.loc2.addr')}</p>
          
          <ul class="distances">
            <li><span>🏢 {t('routing.loc2.d1')}</span> <strong>200m (3 min)</strong></li>
            <li><span>🏖️ {t('routing.loc2.d2')}</span> <strong>100m (1 min)</strong></li>
          </ul>

          <div class="map-container">
             <iframe 
             src="https://maps.google.com/maps?q=Cra.+2+%2319-36,+Santa+Marta,+Centro+Hist%C3%B3rico&t=&z=16&ie=UTF8&iwloc=&output=embed" 
             width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
           </iframe>
          </div>

          <div class="routing-actions">
            <a href={`https://waze.com/ul?ll=${loc2Lat},${loc2Lon}&navigate=yes`} target="_blank" class="btn btn-secondary btn-waze">
              {t('routing.btn.waze')}
            </a>
            <a href={`https://www.google.com/maps/dir/?api=1&destination=${loc2Lat},${loc2Lon}`} target="_blank" class="btn btn-primary btn-maps">
              {t('routing.btn.maps')}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .matrix-section {
    background-color: #0b1120;
  }

  .mb-5 { margin-bottom: 3rem; }
  .text-center { text-align: center; }
  .text-secondary { color: var(--text-secondary); }

  .matrix-header h2 {
    font-size: 2.5rem;
    color: var(--text-primary);
  }

  .matrix-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .matrix-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-image img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-bottom: 3px solid var(--primary-color);
  }

  .card-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-content h3 {
    font-size: 1.5rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  .address {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .distances {
    list-style: none;
    margin-bottom: 1.5rem;
    background: rgba(0,0,0,0.2);
    padding: 1rem;
    border-radius: 8px;
  }

  .distances li {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .distances li:last-child {
    margin-bottom: 0;
  }

  .map-container {
    margin-bottom: 1.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .routing-actions {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
