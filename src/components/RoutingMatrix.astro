---
// RoutingMatrix.astro
const loc1Lat = "11.2423592";
const loc1Lon = "-74.2143214";

const loc2Lat = "11.2426731";
const loc2Lon = "-74.214182";
---

<section id="locations" class="section matrix-section">
  <div class="container">
    <div class="matrix-header text-center mb-5">
      <h2>Our Locations</h2>
      <p class="text-secondary">Select the most convenient parking lot for your destination.</p>
    </div>

    <div class="matrix-grid">
      <!-- Location 1 -->
      <div class="matrix-card glass-panel">
        <div class="card-image">
          <img src="/images/location1.png" alt="RCBA Parking 1 (Centro Histórico)" />
        </div>
        <div class="card-content">
          <h3>RCBA Parking 1</h3>
          <p class="address">Cra. 2 #19-60, Centro Histórico</p>
          
          <ul class="distances">
            <li><span>🚶 Marina Santa Marta:</span> <strong>200m (3 min)</strong></li>
            <li><span>🏛️ Parque de los Novios:</span> <strong>400m (5 min)</strong></li>
          </ul>

          <div class="map-container">
            <!-- Google Maps Embed for Cra 2 #19-60 -->
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3913.0645069796033!2d-74.2143214!3d11.2423592!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8ef4f5a3a4bbbbbb%3A0xbbbbbbbbbbbbbbbb!2sCra.%202%20%2319-60%2C%20Santa%20Marta%2C%20Magdalena!5e0!3m2!1sen!2sco!4v1680000000000!5m2!1sen!2sco" 
              width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>

          <div class="routing-actions">
            <a href={`waze://?ll=${loc1Lat},${loc1Lon}&navigate=yes`} class="btn btn-waze btn-large">
              Drive with Waze
            </a>
            <a href={`https://www.google.com/maps/dir/?api=1&destination=${loc1Lat},${loc1Lon}`} target="_blank" rel="noopener noreferrer" class="btn btn-maps btn-large">
              Drive with Google Maps
            </a>
          </div>
        </div>
      </div>

      <!-- Location 2 -->
      <div class="matrix-card glass-panel">
        <div class="card-image">
          <img src="/images/location2.png" alt="RCBA Parking 2" />
        </div>
        <div class="card-content">
          <h3>RCBA Parking 2</h3>
          <p class="address">Cra. 2 #19-36, Centro Histórico</p>
          
          <ul class="distances">
            <li><span>🏢 Centro Comercial:</span> <strong>500m (6 min)</strong></li>
            <li><span>🏖️ Bahia Santa Marta:</span> <strong>600m (8 min)</strong></li>
          </ul>

          <div class="map-container">
             <!-- Placeholder Map Embed -->
             <iframe 
             src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3913.0645069796033!2d-74.214182!3d11.2426731!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8ef4f5a3a4bbbbbb%3A0xbbbbbbbbbbbbbbbb!2sCra.%202%20%2319-36%2C%20Santa%20Marta%2C%20Magdalena!5e0!3m2!1sen!2sco!4v1680000000000!5m2!1sen!2sco" 
             width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
           </iframe>
          </div>

          <div class="routing-actions">
            <a href={`waze://?ll=${loc2Lat},${loc2Lon}&navigate=yes`} class="btn btn-waze btn-large">
              Drive with Waze
            </a>
            <a href={`https://www.google.com/maps/dir/?api=1&destination=${loc2Lat},${loc2Lon}`} target="_blank" rel="noopener noreferrer" class="btn btn-maps btn-large">
              Drive with Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .matrix-section {
    background-color: #0b1120;
  }

  .mb-5 { margin-bottom: 3rem; }
  .text-center { text-align: center; }
  .text-secondary { color: var(--text-secondary); }

  .matrix-header h2 {
    font-size: 2.5rem;
    color: var(--text-primary);
  }

  .matrix-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .matrix-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-image img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-bottom: 3px solid var(--primary-color);
  }

  .card-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-content h3 {
    font-size: 1.5rem;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
  }

  .address {
    font-size: 1.1rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .distances {
    list-style: none;
    margin-bottom: 1.5rem;
    background: rgba(0,0,0,0.2);
    padding: 1rem;
    border-radius: 8px;
  }

  .distances li {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .distances li:last-child {
    margin-bottom: 0;
  }

  .map-container {
    margin-bottom: 1.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .routing-actions {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
