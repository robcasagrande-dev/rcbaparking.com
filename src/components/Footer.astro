---
// Footer.astro
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="brand-col">
      <h3>RCBA <span class="highlight">Parking</span></h3>
      <p class="text-secondary">Secure, 24/7 parking in the heart of Santa Marta. Two locations to serve you better.</p>
    </div>
    
    <div class="links-col">
      <h4>Connect With Us</h4>
      <ul class="social-links">
        <li>
          <strong>Location 1:</strong>
          <a href="https://facebook.com/rcbaparking" target="_blank" rel="noopener noreferrer">Facebook</a> | 
          <a href="https://instagram.com/rcbaparking" target="_blank" rel="noopener noreferrer">Instagram</a>
        </li>
        <li>
          <strong>Location 2:</strong>
          <a href="https://facebook.com/profile.php?id=61557544546633" target="_blank" rel="noopener noreferrer">Facebook</a> | 
          <a href="https://instagram.com/rcbaparking2" target="_blank" rel="noopener noreferrer">Instagram</a>
        </li>
      </ul>
    </div>
    
    <div class="legal-col">
      <h4>Legal</h4>
      <ul class="legal-links">
        <li><a href="#terms">Terms of Service</a></li>
        <li><a href="#privacy">Privacy Policy</a></li>
        <li><a href="#liability">Liability Disclaimer</a></li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom text-center">
    <p class="text-secondary">&copy; {new Date().getFullYear()} RCBA Parking. All rights reserved.</p>
  </div>

  <!-- WhatsApp Floating Widget -->
  <a href="https://wa.me/5754220888" target="_blank" rel="noopener noreferrer" class="whatsapp-widget" aria-label="Chat on WhatsApp">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.666.598 1.216.774 1.39.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-5.824 4.74-10.563 10.564-10.563 5.826 0 10.564 4.738 10.564 10.561s-4.738 10.565-10.564 10.565z"/>
    </svg>
  </a>
</footer>

<style>
  .footer {
    background-color: #0b1120;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .highlight {
    color: var(--primary-color);
  }

  h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  h4 {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .text-secondary {
    color: var(--text-secondary);
  }

  ul {
    list-style: none;
  }

  .social-links li, .legal-links li {
    margin-bottom: 1rem;
  }

  .social-links a, .legal-links a {
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .social-links a:hover, .legal-links a:hover {
    color: var(--primary-color);
  }

  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* WhatsApp Widget */
  .whatsapp-widget {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background-color: #25D366;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
    z-index: 1000;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .whatsapp-widget:hover {
    transform: scale(1.1) translateY(-5px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.6);
  }
</style>
