---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="brand-col">
      <div class="footer-logos">
        <img src="/images/logo1.jpeg" alt="RCBA Parking Logo" class="footer-logo" />
        <img src="/images/logo2.jpeg" alt="RCBA Parking 2 Logo" class="footer-logo" />
      </div>
      <p class="text-secondary">{t('footer.desc')}</p>
      
      <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(255, 255, 255, 0.05); border-radius: 8px; border-left: 3px solid var(--primary-color);">
        <h4 style="margin-bottom: 0.5rem; font-size: 1rem; color: var(--primary-color);">🏢 {t('footer.partner.title')}</h4>
        <p class="text-secondary" style="font-size: 0.9rem; margin-bottom: 0.5rem;">
          {t('footer.partner.desc')} <a href="https://kalihotels.com" target="_blank" rel="noopener noreferrer" style="color: white; font-weight: bold; text-decoration: underline;">Kali Hotels</a>.
        </p>
        <p class="text-secondary" style="font-size: 0.9rem; margin-bottom: 0.2rem;">
          {t('footer.partner.code')} <strong style="color: var(--primary-color);">{t('footer.partner.discount')}</strong>
        </p>
        <p class="text-secondary" style="font-size: 0.75rem; margin-bottom: 0; opacity: 0.8;">
          {t('footer.partner.disclaimer')}
        </p>
      </div>
    </div>
    
    <div class="links-col">
      <h4>{t('footer.connect')}</h4>
      <p><strong>{t('footer.loc1')}</strong> Cra. 2 #19-60</p>
      <p><strong>{t('footer.loc2')}</strong> Cra. 2 #19-36</p>
      <div class="social-links">
        <a href="https://www.facebook.com/rcbaparking" target="_blank" aria-label="Facebook Location 1">FB 1</a>
        <a href="https://www.instagram.com/rcbaparking?igsh=NHRjcGJkc3piNDAz&utm_source=qr" target="_blank" aria-label="Instagram Location 1">IG 1</a>
        <a href="https://www.facebook.com/profile.php?id=61557544546633" target="_blank" aria-label="Facebook Location 2">FB 2</a>
        <a href="https://www.instagram.com/rcbaparking2?igsh=aTJqNzF3dTMxcDU3&utm_source=qr" target="_blank" aria-label="Instagram Location 2">IG 2</a>
      </div>
    </div>
    
    <div class="links-col">
      <h4>{t('footer.legal')}</h4>
      <ul>
        <li><a href="#">{t('footer.terms')}</a></li>
        <li><a href="#">{t('footer.privacy')}</a></li>
        <li><a href="#">{t('footer.liability')}</a></li>
      </ul>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <p class="text-secondary">© {new Date().getFullYear()} RCBA Parking. {t('footer.rights')}</p>
  </div>

  <!-- WhatsApp Floating Widget -->
  <a href="https://wa.me/5754220888" target="_blank" rel="noopener noreferrer" class="whatsapp-widget" aria-label="Chat on WhatsApp">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.77-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.666.598 1.216.774 1.39.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-5.824 4.74-10.563 10.564-10.563 5.826 0 10.564 4.738 10.564 10.561s-4.738 10.565-10.564 10.565z"/>
    </svg>
  </a>
</footer>

<style>
  .footer {
    background-color: #0b1120;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-logos {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
    align-items: center;
  }

  .footer-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    background: white; /* Contrast for the dark footer */
    padding: 0.2rem;
    border-radius: 4px;
  }

  h4 {
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .text-secondary {
    color: var(--text-secondary);
  }

  ul {
    list-style: none;
  }

  .social-links li, .legal-links li {
    margin-bottom: 1rem;
  }

  .social-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .social-links a, .legal-links a {
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .social-links a:hover, .legal-links a:hover {
    color: var(--primary-color);
  }

  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  /* WhatsApp Widget */
  .whatsapp-widget {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background-color: #25D366;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
    z-index: 1000;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .whatsapp-widget:hover {
    transform: scale(1.1) translateY(-5px);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.6);
  }
</style>
