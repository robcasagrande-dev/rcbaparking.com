---
// Pricing.astro
---

<section id="pricing" class="section pricing-section">
  <div class="container">
    <div class="text-center mb-5">
      <h2>Pricing Structure</h2>
      <p class="text-secondary">Transparent, affordable rates for secure parking.</p>
    </div>

    <div class="pricing-grid">
      <!-- Daytime -->
      <div class="pricing-card glass-panel">
        <div class="pricing-header">
          <h3>Daytime Flat Rate</h3>
          <div class="price">
            <span class="currency">COP</span>
            <span class="amount">20,000</span>
          </div>
          <p class="validity">Valid until 18:00</p>
        </div>
        <div class="pricing-body">
          <ul>
            <li>✓ Ideal for daytime catamaran excursions</li>
            <li>✓ Perfect for sailing tours</li>
            <li>✓ Secure physical monitoring</li>
            <li>✓ Convenient marina access</li>
          </ul>
        </div>
      </div>

      <!-- Evening -->
      <div class="pricing-card glass-panel featured">
        <div class="pricing-header">
          <h3>Evening Hourly Rate</h3>
          <div class="price">
            <span class="currency">COP</span>
            <span class="amount">3,000</span>
            <span class="period">/hr</span>
          </div>
          <p class="validity">Applies after 18:00</p>
        </div>
        <div class="pricing-body">
          <ul>
            <li>✓ Enjoy Santa Marta’s nightlife without a curfew</li>
            <li>✓ 00:00-00:00 continuous operating hours</li>
            <li>✓ Safe access to your vehicle at any time of night</li>
            <li>✓ Premium vehicle accommodation</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-section {
    position: relative;
    background-color: var(--bg-color);
  }

  .text-center { text-align: center; }
  .mb-5 { margin-bottom: 3rem; }
  .text-secondary { color: var(--text-secondary); }

  h2 {
    font-size: 2.5rem;
    color: var(--primary-color);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-card {
    padding: 2.5rem;
    border-radius: var(--border-radius);
    text-align: center;
    transition: transform 0.3s ease;
    border-top: 4px solid var(--text-secondary);
  }

  .pricing-card.featured {
    border-top: 4px solid var(--primary-color);
    transform: scale(1.05);
    background: rgba(30, 41, 59, 0.9);
  }

  .pricing-card:hover {
    transform: scale(1.05) translateY(-5px);
  }

  .pricing-header h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .price {
    display: flex;
    justify-content: center;
    align-items: baseline;
    margin-bottom: 0.5rem;
  }

  .currency {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--primary-color);
    margin-right: 0.25rem;
  }

  .amount {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1;
  }

  .period {
    font-size: 1.2rem;
    color: var(--text-secondary);
    margin-left: 0.25rem;
  }

  .validity {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 2rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .pricing-body ul {
    list-style: none;
    text-align: left;
  }

  .pricing-body li {
    margin-bottom: 1rem;
    color: var(--text-primary);
    display: flex;
    align-items: flex-start;
  }

  @media (max-width: 768px) {
    .pricing-card.featured {
      transform: none;
    }
    .pricing-card:hover {
      transform: translateY(-5px);
    }
  }
</style>
