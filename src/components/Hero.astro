---
// Hero.astro
---

<section class="hero">
  <div class="hero-overlay"></div>
  <div class="container hero-content animate-fade-in">
    <h1>Secure, 24/7 Parking in the <span class="highlight">Heart of Santa Marta</span></h1>
    <p class="sub-headline delay-1">
      Two strategically located facilities offering continuous access, 24-hour monitoring, and seamless routing. 
      Just 200 meters from Marina Santa Marta and steps from the Centro Histórico.
    </p>
    <div class="hero-actions delay-2">
      <a href="#locations" class="btn btn-primary btn-large">Find a Parking Spot</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-image: url('/images/hero.png');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    padding-top: 5rem; /* Account for sticky header */
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(15, 23, 42, 0.9) 0%,
      rgba(15, 23, 42, 0.6) 50%,
      rgba(15, 23, 42, 0.8) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin-bottom: 1.5rem;
    color: #fff;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .highlight {
    color: var(--primary-color);
  }

  .sub-headline {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: #e2e8f0;
    margin-bottom: 2.5rem;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    max-width: 700px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
  }
</style>
