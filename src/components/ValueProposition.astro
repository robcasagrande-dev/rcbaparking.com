---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="value-prop" class="section vp-section">
  <div class="container">
    <div class="vp-header text-center animate-fade-in">
      <h2>{t('vp.title')}</h2>
      <p class="vp-intro">{t('vp.p1')}</p>
      <p class="vp-intro mt-4">{t('vp.p2')}</p>
    </div>

    <div class="vp-grid">
      <div class="vp-card glass-panel">
        <div class="icon">🛡️</div>
        <h3>{t('vp.f1.title')}</h3>
        <p>{t('vp.f1.desc')}</p>
      </div>

      <div class="vp-card glass-panel">
        <div class="icon">🕒</div>
        <h3>{t('vp.f2.title')}</h3>
        <p>{t('vp.f2.desc')}</p>
      </div>

      <div class="vp-card glass-panel">
        <div class="icon">📍</div>
        <h3>{t('vp.f3.title')}</h3>
        <p>{t('vp.f3.desc')}</p>
      </div>

      <div class="vp-card glass-panel">
        <div class="icon">🚙</div>
        <h3>{t('vp.f4.title')}</h3>
        <p>{t('vp.f4.desc')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .vp-section {
    background-color: var(--bg-color);
    position: relative;
  }

  .vp-header {
    max-width: 800px;
    margin: 0 auto 4rem auto;
    text-align: center;
  }

  .vp-header h2 {
    font-size: 2.5rem;
    color: var(--primary-color);
    margin-bottom: 1.5rem;
  }

  .vp-intro {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .mt-4 {
    margin-top: 1rem;
  }

  .vp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .vp-card {
    padding: 2.5rem 1.5rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .vp-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    border-color: rgba(250, 204, 21, 0.3);
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
  }

  .vp-card h3 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .vp-card p {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
</style>
